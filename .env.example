# ===== Telegram API credentials (for READING the source channels) =====
# Get these from https://my.telegram.org -> API Development Tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Your personal Telegram phone number, with country code, e.g. +998901234567
# Only needed for the very first run (creates a session file after that)
TELEGRAM_PHONE=

# ===== Your Bot (for SENDING approval messages + posting to your channel) =====
# Token from @BotFather
BOT_TOKEN=

# Your personal Telegram numeric user ID (the bot will send approval requests here)
# Get it by messaging @userinfobot on Telegram
ADMIN_USER_ID=

# Your channel where approved posts get sent
# Use @yourchannelusername OR the numeric channel ID (e.g. -1001234567890)
# IMPORTANT: your bot must be an ADMIN of this channel with "Post messages" permission
TARGET_CHANNEL=

# ===== Source channels to monitor (Russian football news) =====
# Comma-separated usernames, WITHOUT the @ symbol, e.g. footballrunews,sportexpress
SOURCE_CHANNELS=

# ===== Translation =====
# API key from https://console.anthropic.com
ANTHROPIC_API_KEY=
